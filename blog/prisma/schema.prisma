// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}
type Image {
  chemin      String
  description String
}

type Auteur {
  id        String
  pseudo    String
}

model Article {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  titre        String
  image        Image
  article      String
  utilisateur  Auteur
  utilisateurId String   @db.ObjectId
  date         DateTime
}


model Utilisateur {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId // Mappé à `_id` dans MongoDB
  pseudo        String
  nom           String
  prenom        String
  anniversaire  DateTime
  email         String   @unique
  mdp           String
  date_creation DateTime
  description   String?
}


